<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="-Infinity" minWidth="-Infinity" prefHeight="460.0" prefWidth="700.0" styleClass="container" stylesheets="@../styles/style.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1">

    <top>
        <fx:include source="header.fxml" />
    </top>

    <left>
        <VBox>
            <BorderPane.margin>
                <Insets left="15.0" top="20.0" />
            </BorderPane.margin>
            <fx:include source="sidebar.fxml" />
        </VBox>
    </left>

    <center>
        <VBox prefHeight="200.0" prefWidth="100.0" BorderPane.alignment="CENTER">
            <children>

                <HBox alignment="BOTTOM_CENTER" maxHeight="-Infinity" maxWidth="1.7976931348623157E308" minHeight="-Infinity" minWidth="-Infinity" prefHeight="67.0" prefWidth="555.0">
                    <children>
                        <VBox maxHeight="-Infinity" maxWidth="1.7976931348623157E308" minHeight="-Infinity" minWidth="-Infinity" prefHeight="54.0" HBox.hgrow="ALWAYS">
                            <children>
                                <Label styleClass="titulo-pagina" stylesheets="@../styles/home.css" text="Bem-vindo, Professor!" />
                                <Label styleClass="subtitulo-pagina" stylesheets="@../styles/home.css" text="Gere e edite provas rapidamente a partir de questões já produzidas!" />
                            </children>
                        </VBox>
                    </children>
                    <padding>
                        <Insets bottom="12.0" />
                    </padding>
                </HBox>

                <VBox prefHeight="250.0" prefWidth="582.0" spacing="20.0">
                    <children>

                        <HBox spacing="15.0">
                            <children>

                                <VBox fx:id="cardProvas" prefHeight="130.0" prefWidth="180.0" styleClass="card-dashboard" stylesheets="@../styles/home.css">
                                    <children>
                                        <HBox alignment="TOP_CENTER">
                                            <children>
                                                <Label styleClass="card-titulo" stylesheets="@../styles/home.css" text="Provas" />
                                                <Region HBox.hgrow="ALWAYS" />
                                                <StackPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" prefHeight="32.0" prefWidth="32.0" styleClass="fundo-icone-azul" stylesheets="@../styles/exam.css">
                                                    <children>
                                                        <ImageView fitHeight="18.0" fitWidth="18.0" pickOnBounds="true" preserveRatio="true">
                                                            <image>
                                                                <Image url="@../icons/prova%20(3).png" />
                                                            </image>
                                                        </ImageView>
                                                    </children>
                                                </StackPane>
                                            </children>
                                        </HBox>
                                        <Region VBox.vgrow="ALWAYS" />
                                        <Label fx:id="lblTotalProvas" styleClass="card-numero" stylesheets="@../styles/home.css" text="0" />
                                    </children>
                                </VBox>

                                <VBox fx:id="cardQuestoes" prefHeight="130.0" prefWidth="180.0" styleClass="card-dashboard" stylesheets="@../styles/home.css">
                                    <children>
                                        <HBox alignment="TOP_CENTER">
                                            <children>
                                                <Label styleClass="card-titulo" stylesheets="@../styles/home.css" text="Questões" />
                                                <Region HBox.hgrow="ALWAYS" />
                                                <StackPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" prefHeight="32.0" prefWidth="32.0" styleClass="fundo-icone-azul" stylesheets="@../styles/exam.css">
                                                    <children>
                                                        <ImageView fitHeight="18.0" fitWidth="18.0" pickOnBounds="true" preserveRatio="true">
                                                            <image>
                                                                <Image url="@../icons/prova%20(3).png" />
                                                            </image>
                                                        </ImageView>
                                                    </children>
                                                </StackPane>
                                            </children>
                                        </HBox>
                                        <Region VBox.vgrow="ALWAYS" />
                                        <Label fx:id="lblTotalQuestoes" styleClass="card-numero" stylesheets="@../styles/home.css" text="0" />
                                    </children>
                                </VBox>

                                <VBox fx:id="cardDisciplinas" prefHeight="130.0" prefWidth="180.0" styleClass="card-dashboard" stylesheets="@../styles/home.css">
                                    <children>
                                        <HBox alignment="TOP_CENTER">
                                            <children>
                                                <Label styleClass="card-titulo" stylesheets="@../styles/home.css" text="Disciplinas" />
                                                <Region HBox.hgrow="ALWAYS" />
                                                <StackPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" prefHeight="32.0" prefWidth="32.0" styleClass="fundo-icone-azul" stylesheets="@../styles/exam.css">
                                                    <children>
                                                        <ImageView fitHeight="18.0" fitWidth="18.0" pickOnBounds="true" preserveRatio="true">
                                                            <image>
                                                                <Image url="@../icons/prova%20(3).png" />
                                                            </image>
                                                        </ImageView>
                                                    </children>
                                                </StackPane>
                                            </children>
                                        </HBox>
                                        <Region VBox.vgrow="ALWAYS" />
                                        <Label fx:id="lblTotalDisciplinas" styleClass="card-numero" stylesheets="@../styles/home.css" text="0" />
                                    </children>
                                </VBox>

                            </children>
                        </HBox>

                        <HBox spacing="15.0">
                            <children>

                                <Button fx:id="btnNovaProva" maxWidth="1.7976931348623157E308" mnemonicParsing="false" prefHeight="80.0" styleClass="card-acao-home" stylesheets="@../styles/home.css" HBox.hgrow="ALWAYS">
                                    <graphic>
                                        <HBox alignment="CENTER_LEFT" spacing="12.0">
                                            <children>
                                                <StackPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" prefHeight="40.0" prefWidth="40.0" styleClass="fundo-icone-azul" stylesheets="@../styles/exam.css">
                                                    <children>
                                                        <Label style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-translate-y: -2px;" text="+" textFill="WHITE" />
                                                    </children>
                                                </StackPane>
                                                <VBox alignment="CENTER_LEFT" spacing="2.0">
                                                    <children>
                                                        <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #000000;" text="Nova prova" />
                                                        <Label style="-fx-font-size: 12px; -fx-text-fill: #64748b;" text="Gerar prova com questões aleatórias" />
                                                    </children>
                                                </VBox>
                                            </children>
                                        </HBox>
                                    </graphic>
                                </Button>

                                <Button fx:id="btnNovaQuestao" maxWidth="1.7976931348623157E308" mnemonicParsing="false" prefHeight="80.0" styleClass="card-acao-home" stylesheets="@../styles/home.css" HBox.hgrow="ALWAYS">
                                    <graphic>
                                        <HBox alignment="CENTER_LEFT" spacing="12.0">
                                            <children>
                                                <StackPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" prefHeight="40.0" prefWidth="40.0" styleClass="fundo-icone-azul" stylesheets="@../styles/exam.css">
                                                    <children>
                                                        <Label style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-translate-y: -2px;" text="+" textFill="WHITE" />
                                                    </children>
                                                </StackPane>
                                                <VBox alignment="CENTER_LEFT" spacing="2.0">
                                                    <children>
                                                        <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #000000;" text="Nova questão" />
                                                        <Label style="-fx-font-size: 12px; -fx-text-fill: #64748b;" text="Cadastrar nova questão" />
                                                    </children>
                                                </VBox>
                                            </children>
                                        </HBox>
                                    </graphic>
                                </Button>

                            </children>
                        </HBox>

                    </children>
                </VBox>
            </children>

            <padding>
                <Insets right="20.0" top="15.0" />
            </padding>
        </VBox>
    </center>

</BorderPane>